<Application x:Class="HsRotaryClub.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HsRotaryClub.App"
             xmlns:vm="clr-namespace:HsRotaryClub.App.ViewModels"
             xmlns:views="clr-namespace:HsRotaryClub.App.Views"
             xmlns:infra="clr-namespace:HsRotaryClub.App.Infrastructure"
             xml:lang="zh-TW">
    <Application.Resources>
        <ResourceDictionary>
            <!-- v0.58: DateOnly? ↔ DateTime? converter for DatePicker binding (Club.CharterDate is DateOnly?) -->
            <infra:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTime"/>
            <!-- v0.17: global CJK FontFamily fallback chain (繁中 → 日文 → 簡中 → 英文) -->
            <FontFamily x:Key="AppFontFamily">Microsoft JhengHei, Microsoft YaHei, Meiryo, SimSun, Segoe UI</FontFamily>
            <Style TargetType="{x:Type Window}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type Button}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type DataGrid}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type DatePicker}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type Menu}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type MenuItem}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Background" Value="#E8F0F8"/>
            </Style>
            <DataTemplate DataType="{x:Type vm:MemberViewModel}">
                <views:MemberPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ClubCollectionViewModel}">
                <views:ClubCollectionPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FriendlyClubViewModel}">
                <views:FriendlyClubPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
                <views:AttendancePage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OtherTransactionViewModel}">
                <views:OtherTransactionPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AccountingViewModel}">
                <views:AccountingPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MailViewModel}">
                <views:MailPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomePage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ClubManagementViewModel}">
                <views:ClubManagementPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>