<Application x:Class="HsRotaryClub.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HsRotaryClub.App"
             xmlns:vm="clr-namespace:HsRotaryClub.App.ViewModels"
             xmlns:views="clr-namespace:HsRotaryClub.App.Views"
             >
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:MemberViewModel}">
                <views:MemberPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ClubCollectionViewModel}">
                <views:ClubCollectionPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FriendlyClubViewModel}">
                <views:FriendlyClubPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
                <views:AttendancePage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomePage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ClubManagementViewModel}">
                <views:ClubManagementPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
