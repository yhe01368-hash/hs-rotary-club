<UserControl x:Class="HsRotaryClub.App.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#2E5C8A"/>
            <TextBlock Text="{Binding Subtitle}" FontSize="14" Foreground="Gray" Margin="0,4,0,16"/>
            <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="16" Background="#F8F8F8">
                <StackPanel>
                    <TextBlock Text="本版本範圍" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="4,2" FontSize="14"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <TextBlock Text="{Binding Note}" Margin="0,16" FontStyle="Italic" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
