<UserControl x:Class="HsRotaryClub.App.Views.OtherTransactionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="其它收支管理" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Text="年度:" Margin="20,0,4,0" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Text="{Binding Year}" Width="60" Margin="0,0,8,0"/>

            <TextBlock Text="月份:" Margin="0,0,4,0" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Text="{Binding Month}" Width="40" Margin="0,0,8,0"/>

            <Button Content="重新載入" Command="{Binding ReloadCommand}" Padding="8,4" Margin="4,0"/>
            <Button Content="新增收入" Command="{Binding AddIncomeCommand}" Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
            <Button Content="儲存收入" Command="{Binding SaveIncomeCommand}" Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="刪除收入" Command="{Binding DeleteIncomeCommand}" Padding="8,4" Margin="4,0"/>
            <Button Content="新增支出" Command="{Binding AddExpenseCommand}" Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
            <Button Content="儲存支出" Command="{Binding SaveExpenseCommand}" Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="刪除支出" Command="{Binding DeleteExpenseCommand}" Padding="8,4" Margin="4,0"/>
        </DockPanel>

        <!-- 中: 左收入 + 右支出 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="💰 其它收入" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                <DataGrid ItemsSource="{Binding Incomes}" SelectedItem="{Binding SelectedIncome}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding TxDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="單據" Binding="{Binding VoucherNo}" Width="80"/>
                        <DataGridTextColumn Header="對象" Binding="{Binding Subject}" Width="100"/>
                        <DataGridTextColumn Header="說明" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="類別" Binding="{Binding Category}" Width="80"/>
                        <DataGridTextColumn Header="金額" Binding="{Binding Amount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#EEE"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="💸 扶輪月支出" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                <DataGrid ItemsSource="{Binding Expenses}" SelectedItem="{Binding SelectedExpense}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding TxDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="單據" Binding="{Binding VoucherNo}" Width="80"/>
                        <DataGridTextColumn Header="對象" Binding="{Binding Subject}" Width="100"/>
                        <DataGridTextColumn Header="說明" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="貸方科目" Binding="{Binding CreditAccount}" Width="80"/>
                        <DataGridTextColumn Header="類別" Binding="{Binding Category}" Width="80"/>
                        <DataGridTextColumn Header="金額" Binding="{Binding Amount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- 底部摘要 -->
        <Border Grid.Row="2" Background="#F0F0F0" Margin="0,6,0,0" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="本月總收入: " Foreground="Gray"/>
                <TextBlock Text="{Binding TotalIncome, StringFormat=N0}" FontWeight="Bold" Foreground="DarkGreen" Margin="0,0,20,0"/>
                <TextBlock Text="本月總支出: " Foreground="Gray"/>
                <TextBlock Text="{Binding TotalExpense, StringFormat=N0}" FontWeight="Bold" Foreground="DarkRed" Margin="0,0,20,0"/>
                <TextBlock Text="淨額: " Foreground="Gray"/>
                <TextBlock Text="{Binding NetAmount, StringFormat=N0}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkGreen"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>