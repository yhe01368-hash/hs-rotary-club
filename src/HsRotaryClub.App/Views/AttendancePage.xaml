<UserControl x:Class="HsRotaryClub.App.Views.AttendancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="社友例會出席管理" FontSize="18" FontWeight="Bold" Foreground="#1A4789" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Text="年度:" Margin="20,0,4,0" VerticalAlignment="Center" FontWeight="Bold"/>
            <ComboBox x:Name="YearCombo" Width="80" Margin="0,0,8,0"
                      ItemsSource="{Binding Years}" SelectedItem="{Binding Year}" FontSize="14"/>

            <Button Content="重新載入"  Command="{Binding ReloadCommand}"       Padding="8,4" Margin="4,0"/>
            <Button Content="新增組別" Command="{Binding AddGroupCommand}"     Padding="8,4" Margin="4,0"/>
            <Button Content="儲存"     Command="{Binding SaveGroupCommand}"    Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="停用"     Command="{Binding DeactivateGroupCommand}" Padding="8,4" Margin="4,0"/>
        </DockPanel>

        <!-- 中: 上半組別 + 下半記錄 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 上半: 組別 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="📅 年度組別" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center">
                        <Run Text="當前組別出席率:"/>
                        <Run Text="{Binding SelectedGroupRateText, Mode=OneWay}" FontWeight="Bold" Foreground="DarkGreen"/>
                    </TextBlock>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"
                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          IsReadOnly="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="組別" Binding="{Binding GroupName}" Width="80" FontSize="14"/>
                        <DataGridTextColumn Header="組長編號" Binding="{Binding GroupLeaderCode}" Width="80" FontSize="14"/>
                        <DataGridTextColumn Header="組長姓名" Binding="{Binding GroupLeaderName}" Width="100" FontSize="14"/>
                        <DataGridTextColumn Header="組員編號" Binding="{Binding GroupMemberCode}" Width="80" FontSize="14"/>
                        <DataGridTextColumn Header="組員姓名" Binding="{Binding GroupMemberName}" Width="100" FontSize="14"/>
                        <DataGridTextColumn Header="應出席" Binding="{Binding ShouldAttend}" Width="60" FontSize="14"/>
                        <DataGridTextColumn Header="實出席" Binding="{Binding ActualAttend}" Width="60" FontSize="14"/>
                        <DataGridTextColumn Header="補出席" Binding="{Binding MakeupAttend}" Width="60" FontSize="14"/>
                        <DataGridCheckBoxColumn Header="啟用" Binding="{Binding IsActive}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#EEE"/>

            <!-- 下半: 出席記錄 -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 例會出席記錄 (選取的組別)" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Records}"
                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="例會日期" Binding="{Binding MeetingDate, StringFormat=yyyy-MM-dd}" Width="120" FontSize="14"/>
                        <DataGridTextColumn Header="社員編號" Binding="{Binding MemberCode}" Width="80" FontSize="14"/>
                        <DataGridTextColumn Header="社員姓名" Binding="{Binding MemberName}" Width="120" FontSize="14"/>
                        <DataGridTextColumn Header="出席類型" Binding="{Binding Type}" Width="100" FontSize="14"/>
                        <DataGridTextColumn Header="補出席日期" Binding="{Binding MakeupDate, StringFormat=yyyy-MM-dd}" Width="120" FontSize="14"/>
                        <DataGridTextColumn Header="備註" Binding="{Binding Remarks}" Width="*" FontSize="14"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- 底部狀態列 -->
        <Border Grid.Row="2" Background="#F0F0F0" Margin="0,6,0,0" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="組別: " Foreground="Gray"/>
                <TextBlock Text="{Binding Groups.Count}" Margin="0,0,20,0"/>
                <TextBlock Text="記錄: " Foreground="Gray"/>
                <TextBlock Text="{Binding Records.Count}" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkGreen"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>