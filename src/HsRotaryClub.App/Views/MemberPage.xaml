<UserControl x:Class="HsRotaryClub.App.Views.MemberPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,6">
            <TextBlock Text="社員維護" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>
            <Button Content="重新載入" Command="{Binding ReloadCommand}" Padding="8,4" Margin="4,0"/>
            <Button Content="新增"     Command="{Binding AddCommand}"    Padding="8,4" Margin="4,0"/>
            <Button Content="修正資料" Command="{Binding SaveCommand}"   Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="刪除"     Command="{Binding DeleteCommand}" Padding="8,4" Margin="4,0"/>
            <Button Content="社員選出" Command="{Binding PinCommand}"    Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
        </DockPanel>

        <!-- 左: 速查面板 -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#CCC" BorderThickness="1">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="速查" FontWeight="Bold" Margin="0,0,0,4"/>
                    <DockPanel Grid.Row="1">
                        <TextBlock Text="🔍" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
                    </DockPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                        <ToggleButton Content="現任社員" IsChecked="{Binding ShowCurrentOnly}" Padding="6,2"/>
                    </StackPanel>
                </Grid>
                <ListBox ItemsSource="{Binding Members}" SelectedItem="{Binding Selected}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Code}" Width="50"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 中: 分隔 -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#EEE"/>

        <!-- 右: 編輯表單 -->
        <ScrollViewer Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="12" DataContext="{Binding Selected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0 社員編號 -->
                    <RowDefinition Height="Auto"/> <!-- 1 姓名 -->
                    <RowDefinition Height="Auto"/> <!-- 2 英文名 -->
                    <RowDefinition Height="Auto"/> <!-- 3 身份証 -->
                    <RowDefinition Height="Auto"/> <!-- 4 生日 -->
                    <RowDefinition Height="Auto"/> <!-- 5 配偶 -->
                    <RowDefinition Height="Auto"/> <!-- 6 結婚日 -->
                    <RowDefinition Height="Auto"/> <!-- 7 現任 -->
                    <RowDefinition Height="Auto"/> <!-- 8 介紹人 -->
                    <RowDefinition Height="Auto"/> <!-- 9 介紹人姓名 -->
                    <RowDefinition Height="Auto"/> <!-- 10 separator -->
                    <RowDefinition Height="Auto"/> <!-- 11 服務單位 -->
                    <RowDefinition Height="Auto"/> <!-- 12 職稱 -->
                    <RowDefinition Height="Auto"/> <!-- 13 服務地址 -->
                    <RowDefinition Height="Auto"/> <!-- 14 服務電話 -->
                    <RowDefinition Height="Auto"/> <!-- 15 separator -->
                    <RowDefinition Height="Auto"/> <!-- 16 住宅 -->
                    <RowDefinition Height="Auto"/> <!-- 17 組號 -->
                    <RowDefinition Height="Auto"/> <!-- 18 入社日 -->
                    <RowDefinition Height="Auto"/> <!-- 19 遷出日 -->
                    <RowDefinition Height="Auto"/> <!-- 20 遷出原因 -->
                    <RowDefinition Height="Auto"/> <!-- 21 separator -->
                    <RowDefinition Height="Auto"/> <!-- 22 職業 -->
                    <RowDefinition Height="Auto"/> <!-- 23 業務內容 -->
                    <RowDefinition Height="Auto"/> <!-- 24 手機 -->
                    <RowDefinition Height="Auto"/> <!-- 25 Email -->
                    <RowDefinition Height="Auto"/> <!-- 26 RID -->
                    <RowDefinition Height="Auto"/> <!-- 27 英文住址 -->
                </Grid.RowDefinitions>

                <!-- 基本 -->
                <TextBlock Text="社員編號" Grid.Row="0" Grid.Column="0" Margin="2,4" FontWeight="Bold" Foreground="DarkBlue"/>
                <TextBox   Text="{Binding Code, Mode=TwoWay}" Grid.Row="0" Grid.Column="1" Margin="2,4" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Text="社友姓名" Grid.Row="1" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="英文名字" Grid.Row="2" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="身份証字號" Grid.Row="3" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding IdNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="生日" Grid.Row="4" Grid.Column="0" Margin="2,4"/>
                <DatePicker SelectedDate="{Binding Birthday, Mode=TwoWay}" Grid.Row="4" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left"/>

                <TextBlock Text="配偶姓名" Grid.Row="5" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding SpouseName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="結婚紀念日" Grid.Row="6" Grid.Column="0" Margin="2,4"/>
                <DatePicker SelectedDate="{Binding WeddingAnniversary, Mode=TwoWay}" Grid.Row="6" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left"/>

                <CheckBox Content="現任社員 (取消勾選 = 軟刪 / 離社)"
                          IsChecked="{Binding IsCurrent, Mode=TwoWay}"
                          Grid.Row="7" Grid.ColumnSpan="2" Margin="2,8" FontWeight="Bold"/>

                <TextBlock Text="介紹人編號" Grid.Row="8" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding ReferrerCode, Mode=TwoWay}" Grid.Row="8" Grid.Column="1" Margin="2,4" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Text="介紹人姓名" Grid.Row="9" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding ReferrerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="9" Grid.Column="1" Margin="2,4"/>

                <Separator Grid.Row="10" Grid.ColumnSpan="2" Margin="0,8"/>

                <!-- 服務單位 -->
                <TextBlock Text="服務單位名稱" Grid.Row="11" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EmployerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="11" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="職稱" Grid.Row="12" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EmployerTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="12" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="服務地址" Grid.Row="13" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EmployerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="13" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="服務電話" Grid.Row="14" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EmployerTel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="14" Grid.Column="1" Margin="2,4" Width="160" HorizontalAlignment="Left"/>

                <Separator Grid.Row="15" Grid.ColumnSpan="2" Margin="0,8"/>

                <!-- 住宅 -->
                <TextBlock Text="住宅處地址" Grid.Row="16" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding HomeAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="16" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="組號" Grid.Row="17" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding GroupNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="17" Grid.Column="1" Margin="2,4" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Text="入社日期" Grid.Row="18" Grid.Column="0" Margin="2,4"/>
                <DatePicker SelectedDate="{Binding JoinDate, Mode=TwoWay}" Grid.Row="18" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left"/>

                <TextBlock Text="遷出日期" Grid.Row="19" Grid.Column="0" Margin="2,4"/>
                <DatePicker SelectedDate="{Binding LeaveDate, Mode=TwoWay}" Grid.Row="19" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left"/>

                <TextBlock Text="遷出原因" Grid.Row="20" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding LeaveReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="20" Grid.Column="1" Margin="2,4"/>

                <Separator Grid.Row="21" Grid.ColumnSpan="2" Margin="0,8"/>

                <!-- 其他 -->
                <TextBlock Text="職業分類" Grid.Row="22" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding Occupation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="22" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="業務內容" Grid.Row="23" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding BusinessContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="23" Grid.Column="1" Margin="2,4" AcceptsReturn="True" Height="60"/>

                <TextBlock Text="手機" Grid.Row="24" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding Mobile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="24" Grid.Column="1" Margin="2,4" Width="160" HorizontalAlignment="Left"/>

                <TextBlock Text="電子信箱" Grid.Row="25" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="25" Grid.Column="1" Margin="2,4"/>

                <TextBlock Text="RID" Grid.Row="26" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding Rid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="26" Grid.Column="1" Margin="2,4" Width="120" HorizontalAlignment="Left"/>

                <TextBlock Text="英文住址" Grid.Row="27" Grid.Column="0" Margin="2,4"/>
                <TextBox   Text="{Binding EnglishAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="27" Grid.Column="1" Margin="2,4"/>

            </Grid>
        </ScrollViewer>

        <!-- 底部狀態列 -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#F0F0F0" Margin="0,6,0,0" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="筆數: " Foreground="Gray"/>
                <TextBlock Text="{Binding Members.Count}" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkGreen"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
