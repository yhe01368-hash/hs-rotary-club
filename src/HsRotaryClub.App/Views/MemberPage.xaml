<UserControl x:Class="HsRotaryClub.App.Views.MemberPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="社員維護" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="20,0" VerticalAlignment="Center"/>
            <Button Content="重新載入" Command="{Binding ReloadCommand}" Padding="8,4" Margin="4,0"/>
            <Button Content="新增"     Command="{Binding AddCommand}"    Padding="8,4" Margin="4,0"/>
            <Button Content="儲存"     Command="{Binding SaveCommand}"   Padding="8,4" Margin="4,0"/>
            <Button Content="刪除"     Command="{Binding DeleteCommand}" Padding="8,4" Margin="4,0"/>
        </DockPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Members}" SelectedItem="{Binding Selected}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="{Binding Code}" Width="50"/>
                        <TextBlock Text="{Binding Name}" Width="120" FontWeight="Bold"/>
                        <TextBlock Text="{Binding EnglishName}" Width="160"/>
                        <TextBlock Text="{Binding Occupation}" Width="160"/>
                        <TextBlock Text="{Binding Mobile}" Width="120"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
