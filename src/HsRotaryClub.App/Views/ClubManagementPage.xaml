<UserControl x:Class="HsRotaryClub.App.Views.ClubManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="社團管理" FontSize="18" FontWeight="Bold" Foreground="#1A4789" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Text="當前操作社:" Margin="20,0,4,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="DarkBlue"/>
            <TextBlock Text="{Binding CurrentClubName}" VerticalAlignment="Center" FontWeight="Bold" Foreground="DarkBlue"/>

            <CheckBox Content="停用的社" IsChecked="{Binding ShowInactiveOnly}" Margin="20,0,4,0" VerticalAlignment="Center"/>

            <Button Content="重新載入"  Command="{Binding ReloadCommand}"         Padding="8,4" Margin="8,0,4,0"/>
            <Button Content="新增"      Command="{Binding AddCommand}"            Padding="8,4" Margin="4,0"/>
            <Button Content="儲存"      Command="{Binding SaveCommand}"           Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="停用"      Command="{Binding DeactivateCommand}"     Padding="8,4" Margin="4,0"/>
            <Button Content="切為操作社" Command="{Binding MakeCurrentCommand}"  Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
            <Button Content="匯出 / 匯入" Command="{Binding ImportExportCommand}" Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
            <Button Content="📥 mdb 遷移" Command="{Binding MigrateFromMdbCommand}" Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="🔐 License 管理" Click="OpenLicenseAdmin_Click" Padding="8,4" Margin="4,0"/>
            <Button Content="👤 使用者管理" Click="OpenUserMgmt_Click" Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
        </DockPanel>

        <!-- 中: 左速查 + 右表單 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="4">
                        <TextBlock Text="🔍 速查 (社名 / 分區)" FontWeight="Bold" FontSize="15" Foreground="#1A4789"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" FontSize="14"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Clubs}" SelectedItem="{Binding Selected}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="#1A4789"/>
                                    <TextBlock Text="{Binding District}" Foreground="Gray" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#EEE"/>

            <Grid Grid.Column="2" Margin="6" DataContext="{Binding Selected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0 名稱 -->
                    <RowDefinition Height="Auto"/> <!-- 1 分區 -->
                    <RowDefinition Height="Auto"/> <!-- 2 授證日 -->
                    <RowDefinition Height="Auto"/> <!-- 3 聯絡人 -->
                    <RowDefinition Height="Auto"/> <!-- 4 Email -->
                    <RowDefinition Height="Auto"/> <!-- 5 備註 -->
                    <RowDefinition Height="Auto"/> <!-- 6 啟用 -->
                </Grid.RowDefinitions>

                <TextBlock Text="社名" Grid.Row="0" Grid.Column="0" Margin="2,4" FontWeight="Bold"/>
                <TextBox   Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="2,4" FontSize="14"/>

                <TextBlock Text="分區" Grid.Row="1" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding District, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="2,4" FontSize="14"/>

                <TextBlock Text="授證日" Grid.Row="2" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <DatePicker SelectedDate="{Binding CharterDate, Mode=TwoWay}" Grid.Row="2" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="聯絡人" Grid.Row="3" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding Contact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="2,4" Width="200" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="Email" Grid.Row="4" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding ContactEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="2,4" Width="280" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="備註" Grid.Row="5" Grid.Column="0" Margin="2,4" VerticalAlignment="Top"/>
                <TextBox   Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="2,4" AcceptsReturn="True" Height="80" TextWrapping="Wrap" FontSize="14"/>

                <CheckBox Content="啟用"
                          IsChecked="{Binding IsActive, Mode=TwoWay}"
                          Grid.Row="6" Grid.ColumnSpan="2" Margin="2,8"/>
            </Grid>
        </Grid>

        <!-- 底部狀態列 -->
        <Border Grid.Row="2" Background="#F0F0F0" Margin="0,6,0,0" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="筆數: " Foreground="Gray"/>
                <TextBlock Text="{Binding Clubs.Count}" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkGreen"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
