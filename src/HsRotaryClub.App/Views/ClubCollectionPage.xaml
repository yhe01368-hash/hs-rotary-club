<UserControl x:Class="HsRotaryClub.App.Views.ClubCollectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="會內收款" FontSize="18" FontWeight="Bold" Foreground="#1A4789" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Text="年度:" Margin="20,0,4,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Width="60" VerticalAlignment="Center" FontSize="14"/>
            <TextBlock Text="月份:" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Month, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalAlignment="Center" FontSize="14"/>

            <Button Content="重新載入"  Command="{Binding ReloadCommand}"        Padding="8,4" Margin="20,0,4,0"/>
            <Button Content="新增"      Command="{Binding AddCommand}"           Padding="8,4" Margin="4,0"/>
            <Button Content="挑選社員"  Command="{Binding PickMemberCommand}"    Padding="8,4" Margin="4,0" Background="#A0C4FF"/>
            <Button Content="修正"      Command="{Binding SaveCommand}"          Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="刪除"      Command="{Binding DeleteCommand}"        Padding="8,4" Margin="4,0"/>
            <Button Content="轉 CSV"    Command="{Binding ExportCsvCommand}"     Padding="8,4" Margin="4,0" Background="#C8E6C9"/>
            <Button Content="Recompute" Command="{Binding RecomputeSpecCommand}" Padding="8,4" Margin="4,0" Background="#FFE0B2"/>
        </DockPanel>

        <!-- 上:收款記錄 + 速查 (子 Split: 左速查 / 右表單) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="4">
                        <TextBlock Text="🔍 速查(本月)" FontWeight="Bold" FontSize="15" Foreground="#1A4789"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" FontSize="14"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Collections}" SelectedItem="{Binding Selected}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding CollectionDate, StringFormat=yyyy/M/d}" Width="80"/>
                                    <TextBlock Text="{Binding MemberName}" Width="120"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#EEE"/>

            <Grid Grid.Column="2" Margin="6" DataContext="{Binding Selected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0 序號 (顯示用) -->
                    <RowDefinition Height="Auto"/>  <!-- 1 收款日期 -->
                    <RowDefinition Height="Auto"/>  <!-- 2 社員編號 -->
                    <RowDefinition Height="Auto"/>  <!-- 3 社員姓名 -->
                    <RowDefinition Height="Auto"/>  <!-- 4 收款類別 -->
                    <RowDefinition Height="Auto"/>  <!-- 5 收現金 -->
                    <RowDefinition Height="Auto"/>  <!-- 6 票據金額 -->
                    <RowDefinition Height="Auto"/>  <!-- 7 合計金額 -->
                    <RowDefinition Height="Auto"/>  <!-- 8 帳單 -->
                    <RowDefinition Height="Auto"/>  <!-- 9 收款人 -->
                </Grid.RowDefinitions>

                <TextBlock Text="收款日期" Grid.Row="1" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <!-- v0.35: 改綁 VM.NewDate (獨立屬性),不綁 Selected.CollectionDate (避免 user 改日期寫入舊 row) -->
                <DatePicker SelectedDate="{Binding DataContext.NewDate, RelativeSource={RelativeSource AncestorType=Page}, Mode=TwoWay}" Grid.Row="1" Grid.Column="1" Margin="2,4" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="社員編號" Grid.Row="2" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding MemberCode, Mode=TwoWay}" Grid.Row="2" Grid.Column="1" Margin="2,4" Width="80" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="社員姓名" Grid.Row="3" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding MemberName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="2,4" FontSize="14"/>

                <TextBlock Text="收款類別" Grid.Row="4" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <ComboBox   Grid.Row="4" Grid.Column="1" Margin="2,4"
                            IsEditable="True"
                            Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBoxItem Content="會費" FontSize="14"/>
                    <ComboBoxItem Content="例餐" FontSize="14"/>
                    <ComboBoxItem Content="臨時捐款" FontSize="14"/>
                    <ComboBoxItem Content="扶輪基金" FontSize="14"/>
                    <ComboBoxItem Content="RI 捐款" FontSize="14"/>
                    <ComboBoxItem Content="雜項" FontSize="14"/>
                </ComboBox>

                <TextBlock Text="收現金" Grid.Row="5" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox Text="{Binding CashAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="5" Grid.Column="1" Margin="2,4" Width="120" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="票據金額" Grid.Row="6" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox Text="{Binding CheckAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="6" Grid.Column="1" Margin="2,4" Width="120" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="合計金額" Grid.Row="7" Grid.Column="0" Margin="2,4" FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0}}"
                           Grid.Row="7" Grid.Column="1" Margin="2,4" FontWeight="Bold" Foreground="DarkRed"/>

                <TextBlock Text="帳單" Grid.Row="8" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox Text="{Binding ReceiptNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="8" Grid.Column="1" Margin="2,4" FontSize="14"/>

                <TextBlock Text="收款人" Grid.Row="9" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox Text="{Binding Collector, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="9" Grid.Column="1" Margin="2,4" Width="160" HorizontalAlignment="Left" FontSize="14"/>
            </Grid>
        </Grid>

        <!-- 下:Receivable Specs (應收) -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1" Margin="0,6,0,0" Padding="4">
            <StackPanel>
                <TextBlock Text="本月應收參考" FontWeight="Bold" FontSize="15" Foreground="#1A4789" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding ReceivableSpecs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="1" Padding="6,4" Margin="2" CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding MemberName}" FontWeight="Bold" FontSize="15" Foreground="#1A4789" Width="100"/>
                                    <TextBlock Text="{Binding Item}" Width="120"/>
                                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}" Width="80"/>
                                    <TextBlock Text="/" Foreground="Gray"/>
                                    <TextBlock Text="{Binding SettledAmount, StringFormat={}{0:N0}}" Width="60" Foreground="DarkGreen"/>
                                    <TextBlock Text="  未收 "/>
                                    <TextBlock Text="{Binding OutstandingAmount, StringFormat={}{0:N0}}" FontWeight="Bold" Foreground="DarkRed"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
