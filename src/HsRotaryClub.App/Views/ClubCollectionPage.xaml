<UserControl x:Class="HsRotaryClub.App.Views.ClubCollectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="會內收款" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="年度:" Margin="20,0,4,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Year}" Width="60" VerticalAlignment="Center"/>
            <TextBlock Text="月份:" Margin="12,0,4,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Month}" Width="40" VerticalAlignment="Center"/>
            <Button Content="重新載入" Command="{Binding ReloadCommand}" Padding="8,4" Margin="20,0,4,0"/>
            <Button Content="新增"     Command="{Binding AddCommand}"    Padding="8,4" Margin="4,0"/>
            <Button Content="刪除"     Command="{Binding DeleteCommand}" Padding="8,4" Margin="4,0"/>
        </DockPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Collections}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  x:Name="Grid"/>
    </Grid>
</UserControl>
