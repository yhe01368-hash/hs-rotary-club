<UserControl x:Class="HsRotaryClub.App.Views.FriendlyClubPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="友社捐款" FontSize="18" FontWeight="Bold" Foreground="#1A4789" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="20,0" VerticalAlignment="Center" Foreground="Gray"/>
            <Button Content="重新載入"  Command="{Binding ReloadCommand}"           Padding="8,4" Margin="20,0,4,0"/>
            <Button Content="新增友社"  Command="{Binding AddClubCommand}"          Padding="8,4" Margin="4,0"/>
            <Button Content="修正"      Command="{Binding SaveClubCommand}"         Padding="8,4" Margin="4,0" Background="#FFD27F"/>
            <Button Content="刪除"      Command="{Binding DeleteClubCommand}"       Padding="8,4" Margin="4,0"/>
            <Button Content="匯出捐款 CSV" Command="{Binding ExportDonationsCsvCommand}" Padding="8,4" Margin="20,0,4,0" Background="#C8E6C9"/>
        </DockPanel>

        <!-- 中: 左速查 + 右表單 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="4">
                        <TextBlock Text="🔍 速查(社團)" FontWeight="Bold" FontSize="15" Foreground="#1A4789"/>
                        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" FontSize="14"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Clubs}" SelectedItem="{Binding Selected}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding ClubCode}" Width="80" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ClubName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#EEE"/>

            <Grid Grid.Column="2" Margin="6" DataContext="{Binding Selected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0 ClubCode -->
                    <RowDefinition Height="Auto"/> <!-- 1 ClubName -->
                    <RowDefinition Height="Auto"/> <!-- 2 Remarks -->
                    <RowDefinition Height="Auto"/> <!-- 3 IsActive -->
                </Grid.RowDefinitions>

                <TextBlock Text="社團代號" Grid.Row="0" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding ClubCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="2,4" Width="120" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="社團名稱" Grid.Row="1" Grid.Column="0" Margin="2,4" FontSize="14" FontWeight="Bold" Foreground="#1A4789"/>
                <TextBox   Text="{Binding ClubName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="2,4" FontSize="14"/>

                <TextBlock Text="備註" Grid.Row="2" Grid.Column="0" Margin="2,4" VerticalAlignment="Top"/>
                <TextBox   Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="2,4" AcceptsReturn="True" Height="50" FontSize="14"/>

                <CheckBox Content="啟用"
                          IsChecked="{Binding IsActive, Mode=TwoWay}"
                          Grid.Row="3" Grid.ColumnSpan="2" Margin="2,8"/>
            </Grid>
        </Grid>

        <!-- 下: 捐款記錄 + 快速新增列 -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1" Margin="0,6,0,0">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="捐款往來記錄" FontWeight="Bold" Margin="0,0,0,4"/>

                <!-- 快速新增 -->
                <Grid Grid.Row="1" Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="新增:" VerticalAlignment="Center"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding NewDonationDate, Mode=TwoWay}" Margin="4,0" FontSize="14"/>

                    <TextBlock Grid.Column="2" Text="  方向:" VerticalAlignment="Center" Margin="6,0"/>
                    <ComboBox   Grid.Column="3" SelectedIndex="{Binding NewDonationDirection}" Margin="2,0">
                        <ComboBoxItem Content="Out" FontSize="14"/>  <!-- 0 -->
                        <ComboBoxItem Content="In" FontSize="14"/>   <!-- 1 -->
                    </ComboBox>

                    <TextBlock Grid.Column="4" Text="  金額:" VerticalAlignment="Center" Margin="6,0"/>
                    <TextBox   Grid.Column="5" Text="{Binding NewDonationAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="14"/>

                    <TextBlock Grid.Column="6" Text="  用途:" VerticalAlignment="Center" Margin="6,0"/>
                    <TextBox   Grid.Column="7" Text="{Binding NewDonationPurpose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="14"/>

                    <Button   Grid.Column="7" Content="+ 新增" Command="{Binding AddDonationCommand}" HorizontalAlignment="Right" Padding="10,3" Margin="60,0,0,0"/>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Donations}"
                          SelectedItem="{Binding SelectedDonation}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
