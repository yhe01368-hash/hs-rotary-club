<UserControl x:Class="HsRotaryClub.App.Views.FriendlyClubPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="友社對照" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="重新載入" Command="{Binding ReloadCommand}" Padding="8,4" Margin="20,0,4,0"/>
            <Button Content="新增"     Command="{Binding AddCommand}"    Padding="8,4" Margin="4,0"/>
            <Button Content="儲存"     Command="{Binding SaveCommand}"   Padding="8,4" Margin="4,0"/>
            <Button Content="刪除"     Command="{Binding DeleteCommand}" Padding="8,4" Margin="4,0"/>
        </DockPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Clubs}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="True"
                  IsReadOnly="False"/>
    </Grid>
</UserControl>
