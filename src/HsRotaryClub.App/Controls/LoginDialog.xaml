<UserControl x:Class="HsRotaryClub.App.Controls.LoginDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420" Height="280">
    <Border BorderBrush="#1A4789" BorderThickness="2" Background="White" Padding="24">
        <StackPanel>
            <TextBlock Text="HsRotaryClub 登入" FontSize="20" FontWeight="Bold" Foreground="#1A4789"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="13" Margin="0,0,0,8"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="帳號" FontSize="14" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,4"/>
                <TextBox x:Name="UsernameBox" FontSize="14" Padding="6" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

                <TextBlock Text="密碼" FontSize="14" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,4"/>
                <PasswordBox x:Name="PasswordBox" FontSize="14" Padding="6" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button x:Name="OkButton" Content="登入" Width="100" Padding="8,6" Margin="4"
                        Background="#1A4789" Foreground="White" FontWeight="Bold" Click="Ok_Click"
                        IsDefault="True"/>
                <Button x:Name="CancelButton" Content="取消" Width="100" Padding="8,6" Margin="4"
                        Click="Cancel_Click" IsCancel="True"/>
            </StackPanel>

            <TextBlock Text="預設帳號: admin / 密碼: admin (首次登入後請修改)"
                       FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
