<Window x:Class="HsRotaryClub.App.Controls.ImportExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="資料匯出 / 匯入"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 切換 tabs -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <ToggleButton x:Name="ExportTab" Content="📤 匯出" IsChecked="True" Margin="0,0,4,0" Padding="14,5" Click="Tab_Click"/>
            <ToggleButton x:Name="ImportTab" Content="📥 匯入" Margin="0,0,4,0" Padding="14,5" Click="Tab_Click"/>
        </StackPanel>

        <!-- 共用:選檔 / 檔案資訊 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="檔案:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="PathBox" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button x:Name="BrowseBtn" Grid.Column="2" Content="瀏覽…" Click="BrowseBtn_Click" Padding="10,4" Margin="0,0,4,0"/>
            <Button x:Name="ExecuteBtn" Grid.Column="3" Content="執行" Click="ExecuteBtn_Click" Padding="14,4" Background="#FFD27F"/>
        </Grid>

        <!-- 匯出 / 匯入 預覽區 -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PreviewPanel" Margin="10">

                    <!-- 匯出預覽 -->
                    <StackPanel x:Name="ExportPreview">
                        <TextBlock Text="📤 匯出預覽" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="選擇要匯出的範圍,然後按「執行」匯出。" Foreground="Gray" Margin="0,0,0,8"/>
                        <RadioButton x:Name="ExpAllActive" Content="匯出所有 active 社 (推薦)" IsChecked="True" GroupName="exp" Margin="0,4"/>
                        <RadioButton x:Name="ExpOneClub" Content="只匯出當前操作社:" GroupName="exp" Margin="0,4"/>
                        <TextBlock x:Name="CurrentClubLabel" Text="(未選)" Foreground="Gray" Margin="20,4,0,4"/>
                    </StackPanel>

                    <!-- 匯入預覽 -->
                    <StackPanel x:Name="ImportPreview" Visibility="Collapsed">
                        <TextBlock Text="📥 匯入預覽" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="選擇 .json 匯出檔,預覽內容後按「執行」匯入。" Foreground="Gray" Margin="0,0,0,8"/>

                        <TextBlock x:Name="PreviewHeader" Text="" FontWeight="Bold" Margin="0,8,0,4" Visibility="Collapsed"/>
                        <Border x:Name="PreviewBox" Background="#F5F5F5" Padding="10,8" CornerRadius="4" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="PreviewClubsCount" Text=""/>
                                <TextBlock x:Name="PreviewMembersCount" Text=""/>
                                <TextBlock x:Name="PreviewCollectionsCount" Text=""/>
                                <TextBlock x:Name="PreviewReceivablesCount" Text=""/>
                                <TextBlock x:Name="PreviewFriendlyCount" Text=""/>
                                <TextBlock x:Name="PreviewDonationsCount" Text=""/>
                                <TextBlock x:Name="PreviewSchema" Text="" Foreground="Gray" Margin="0,6,0,0"/>
                                <TextBlock x:Name="PreviewExportedAt" Text="" Foreground="Gray"/>
                            </StackPanel>
                        </Border>

                        <CheckBox x:Name="SkipExisting" Content="跳過已存在的資料 (推薦)" IsChecked="True" Margin="0,8"/>
                    </StackPanel>

                    <!-- 結果 -->
                    <TextBlock x:Name="ResultMessage" Text="" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 底部按鈕 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="關閉" IsCancel="True" Padding="14,5"/>
        </StackPanel>
    </Grid>
</Window>
