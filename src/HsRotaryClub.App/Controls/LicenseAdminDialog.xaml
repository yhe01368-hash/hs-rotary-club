<Window x:Class="HsRotaryClub.App.Controls.LicenseAdminDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License 管理員 (祐哥用)"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="🔐 License 管理員" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="v0.9.1 — 開發者工具:產生 license.dat 給 user / 自己重發" Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#FFF6D8" Padding="10,8" CornerRadius="4" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="本機 MachineId (要給 user 抄):" FontWeight="Bold"/>
                <TextBlock x:Name="MachineIdText" Text="(讀取中...)" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1">
            <StackPanel Margin="10">
                <TextBlock Text="📋 發行參數:" FontWeight="Bold" Margin="0,0,0,6"/>

                <TextBlock Text="發行給:"/>
                <TextBox x:Name="IssuedToBox" Padding="4,2" Margin="0,4,0,8"/>

                <TextBlock Text="Issuer (預設祐哥):"/>
                <TextBox x:Name="IssuerBox" Text="HsRotaryClub Admin (祐哥 / Chia Chang)" Padding="4,2" Margin="0,4,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="有效天數 (0 = 永久):"/>
                        <TextBox x:Name="DaysBox" Text="365" Padding="4,2" Margin="0,4,0,8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="MaxClubs (0 = 不限):"/>
                        <TextBox x:Name="MaxClubsBox" Text="5" Padding="4,2" Margin="0,4,0,8"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="BindMachine" Content="綁定本機 (User 只在這台用)" IsChecked="True" Margin="0,4,0,8"/>

                <Button Content="⚡ 發行 license" Click="IssueBtn_Click" Background="#A0C4FF" Padding="12,6" Margin="0,8,0,8"/>

                <Border Background="#F0F0F0" Padding="8" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="當前 license.dat 內容:" FontWeight="Bold"/>
                        <TextBlock x:Name="LicenseContent" Text="(尚未讀取)" FontFamily="Consolas" TextWrapping="Wrap" MaxHeight="160" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="重新讀取 license" Click="Reload_Click" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="關閉" IsCancel="True" Padding="14,5"/>
        </StackPanel>
    </Grid>
</Window>