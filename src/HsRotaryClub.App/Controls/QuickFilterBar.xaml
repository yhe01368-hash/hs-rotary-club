<UserControl x:Class="HsRotaryClub.App.Controls.QuickFilterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4">
        <TextBlock Text="🔍" VerticalAlignment="Center" DockPanel.Dock="Left"/>
        <TextBlock Text="速查" FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="4,0,8,0"/>
        <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 VerticalAlignment="Center"/>
    </DockPanel>
</UserControl>
