<Window x:Class="HsRotaryClub.App.Controls.MemberLookupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="選擇社員"
        Width="480" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🔍" VerticalAlignment="Center"/>
            <TextBox x:Name="FilterBox" TextChanged="FilterBox_TextChanged" Margin="4,0"/>
        </DockPanel>

        <ListBox Grid.Row="1" x:Name="MembersList" MouseDoubleClick="MembersList_MouseDoubleClick" SelectionChanged="MembersList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Code}" Width="50"/>
                        <!-- v0.44: 當月未繳會費的社員名字標藍色 -->
                        <TextBlock Text="{Binding Name}" Width="160" FontWeight="Bold"
                                   x:Name="NameText">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                            <!-- v0.46.1: 改用 SolidColorBrush (DodgerBlue) — Style setter 內 brush literal string 在某些 WPF 環境需要 SolidColorBrush 實例 -->
                                            <Setter Property="Foreground">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#1E90FF"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding EnglishName}" Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="0,8,0,4">
            <TextBlock x:Name="SelectedInfo" Foreground="DarkGreen" FontStyle="Italic"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="確定" x:Name="OkButton" IsDefault="True" Click="Ok_Click" Padding="14,4" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Padding="14,4"/>
        </StackPanel>
    </Grid>
</Window>
