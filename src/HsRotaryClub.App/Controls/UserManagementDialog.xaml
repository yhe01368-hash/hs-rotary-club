<Window x:Class="HsRotaryClub.App.Controls.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用者管理" Width="700" Height="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft JhengHei, Microsoft YaHei, Segoe UI"
        FontSize="14">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="使用者管理 (admin 專用)"
                   FontSize="18" FontWeight="Bold" Foreground="#1A4789" Margin="0,0,0,8"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="新增使用者" Width="110" Padding="8,6" Margin="4"
                    Background="#A0C4FF" Click="AddUser_Click"/>
            <Button Content="修改密碼" Width="110" Padding="8,6" Margin="4"
                    Background="#FFD27F" Click="ChangePassword_Click"/>
            <Button Content="啟用/停用" Width="110" Padding="8,6" Margin="4"
                    Click="ToggleActive_Click"/>
            <Button Content="刪除" Width="100" Padding="8,6" Margin="4"
                    Background="#FF9090" Click="DeleteUser_Click"/>
            <Button Content="關閉" Width="100" Padding="8,6" Margin="4" Click="Close_Click" IsCancel="True"/>
        </StackPanel>

        <ListView x:Name="UsersList" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="帳號"     DisplayMemberBinding="{Binding Username}"  Width="120"/>
                    <GridViewColumn Header="顯示名稱" DisplayMemberBinding="{Binding DisplayName}" Width="160"/>
                    <GridViewColumn Header="角色"     DisplayMemberBinding="{Binding Role}"      Width="100"/>
                    <GridViewColumn Header="啟用"     DisplayMemberBinding="{Binding IsActive}"  Width="60"/>
                    <GridViewColumn Header="最後登入" DisplayMemberBinding="{Binding LastLoginAt, StringFormat=yyyy-MM-dd HH:mm}" Width="160"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
