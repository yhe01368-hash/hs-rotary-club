<Window x:Class="HsRotaryClub.App.Controls.ClubPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="選擇操作社"
        Width="540" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🌐 選擇操作社" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="HintText" Foreground="Gray" FontSize="12" Margin="0,4,0,0"
                       Text="啟動時選擇本機要操作哪一個社。多社可同 db 並存。"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="6">
                    <TextBlock Text="🔍 速查 (社名)" FontWeight="Bold"/>
                    <TextBox x:Name="FilterBox" TextChanged="FilterBox_TextChanged" Margin="0,4"/>
                </StackPanel>
                <ListBox x:Name="ClubsList" MouseDoubleClick="ClubsList_DoubleClick" SelectionChanged="ClubsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="220"/>
                                <TextBlock Text="{Binding District}" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 內嵌新建社 row -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="或新建:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
            <TextBox x:Name="NewNameBox" Grid.Column="1" Margin="0,0,8,0" Padding="4,2"/>
            <Button Content="建立新社" Grid.Column="2" Click="NewClub_Click" Padding="10,4" Background="#A0C4FF"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="確定" x:Name="OkButton" IsDefault="True" Click="Ok_Click" Padding="14,5" Margin="0,0,8,0" IsEnabled="False"/>
            <Button Content="取消" IsCancel="True" Padding="14,5"/>
        </StackPanel>
    </Grid>
</Window>
