<Window x:Class="HsRotaryClub.App.Controls.MigrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="從舊版 mdb 遷移 (VB6 + Jet)"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="📥 從舊版 VB6 + Jet .mdb 遷移" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="v0.15 — 讀舊版 TS81.mdb 把社員 / 年度組別匯入新 SQLite" Foreground="Gray"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="mdb 檔案:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="PathBox" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button x:Name="BrowseBtn" Grid.Column="2" Content="瀏覽…" Click="BrowseBtn_Click" Padding="10,4" Margin="0,0,4,0"/>
            <Button x:Name="AnalyzeBtn" Grid.Column="3" Content="分析" Click="AnalyzeBtn_Click" Padding="14,4" Background="#A0C4FF"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="📊 mdb 內容預覽:" FontWeight="Bold" FontSize="14"/>

                    <TextBlock x:Name="TablesText" Text="(尚未分析)" Foreground="Gray" TextWrapping="Wrap" Margin="0,4"/>

                    <Border Background="#F0F0F0" Padding="8" Margin="0,8,0,0" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="預期資料:" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="  • Member → 社員 (Member entity)"/>
                            <TextBlock Text="  • TS81_MAT1 → 年度組別 (AttendanceGroup entity)"/>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="DryRun" Content="Dry-run (只預覽,不寫入 db)" IsChecked="True" Margin="0,8,0,4"/>

                    <Button Content="⚡ 開始遷移" Click="MigrateBtn_Click" Background="#FFD27F" Padding="14,6" Margin="0,8,0,8"/>

                    <Border Background="#E8F5E9" Padding="8" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="執行結果:" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ResultText" Text="(尚未執行)" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="關閉" IsCancel="True" Padding="14,5"/>
        </StackPanel>
    </Grid>
</Window>